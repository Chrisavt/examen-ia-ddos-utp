        </mxCell>
        <mxCell id="cleaning" value="&lt;b&gt;Limpieza de Datos&lt;/b&gt;&lt;br&gt;Valores nulos/infinitos&lt;br&gt;Eliminacion de columnas&lt;br&gt;irrelevantes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="110" width="160" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="features" value="&lt;b&gt;Extraccion de Features&lt;/b&gt;&lt;br&gt;77 caracteristicas CICFlowMeter&lt;br&gt;Flow IAT, Packet Len, Flags..." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="320" y="200" width="160" height="80" as="geometry"/>
        </mxCell>

