        <mxCell id="title" value="&lt;b&gt;Arquitectura del Sistema de Deteccion DDoS con ML&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="800" height="40" as="geometry"/>
        </mxCell>

        <!-- ====== CAPA 1: FUENTE DE DATOS ====== -->
        <mxCell id="layer1_label" value="&lt;b&gt;FUENTE DE DATOS&lt;/b&gt;" style="text;html=1;align=left;fontSize=12;fontColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="200" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="dataset" value="&lt;b&gt;CIC-DDoS2019&lt;/b&gt;&lt;br&gt;Dataset CSV (8.2 GB)&lt;br&gt;22M+ flujos etiquetados" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
