<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-07-14T00:00:00.000Z" agent="opencode" version="24.0.0">
  <diagram id="ml-pipeline" name="Pipeline ML">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="&lt;b&gt;Pipeline de Machine Learning — Deteccion DDoS&lt;/b&gt;" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="800" height="40" as="geometry"/>
        </mxCell>

        <!-- Step 1: Dataset -->
        <mxCell id="s1" value="&lt;b&gt;1. CIC-DDoS2019&lt;/b&gt;&lt;br&gt;Dataset original (CSV)&lt;br&gt;~22 millones de flujos&lt;br&gt;77 features + Label" style="shape=document;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="180" height="120" as="geometry"/>
        </mxCell>

        <!-- Step 2: Limpieza -->
        <mxCell id="s2" value="&lt;b&gt;2. Limpieza de Datos&lt;/b&gt;&lt;br&gt;- Eliminar NaN / Inf&lt;br&gt;- Mapear labels a categorias&lt;br&gt;- Eliminar columnas irrelevantes&lt;br&gt;- Submuestreo de BENIGN" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="300" y="100" width="200" height="120" as="geometry"/>
        </mxCell>

        <!-- Step 3: Encoding -->
        <mxCell id="s3" value="&lt;b&gt;3. Codificacion&lt;/b&gt;&lt;br&gt;- LabelEncoder para targets&lt;br&gt;- 7 clases: BENIGN, Syn,&lt;br&gt;  UDP, LDAP, MSSQL,&lt;br&gt;  NetBIOS, Portmap" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="100" width="180" height="120" as="geometry"/>
        </mxCell>

        <!-- Step 4: Split -->
        <mxCell id="s4" value="&lt;b&gt;4. Division&lt;/b&gt;&lt;br&gt;Train: 80%&lt;br&gt;Test: 20%&lt;br&gt;random_state=42" style="rhombus;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="800" y="100" width="160" height="120" as="geometry"/>
        </mxCell>

        <!-- Step 5: Scaling -->
        <mxCell id="s5" value="&lt;b&gt;5. Normalizacion&lt;/b&gt;&lt;br&gt;StandardScaler&lt;br&gt;mean=0, std=1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="800" y="280" width="160" height="80" as="geometry"/>
        </mxCell>

        <!-- Step 6: Training -->
        <mxCell id="s6" value="&lt;b&gt;6. Entrenamiento&lt;/b&gt;" style="text;html=1;align=center;fontSize=13;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="540" y="400" width="200" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="rf_box" value="&lt;b&gt;Random Forest&lt;/b&gt;&lt;br&gt;n_estimators=200&lt;br&gt;max_depth=20&lt;br&gt;accuracy=89.1%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="440" width="160" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="xgb_box" value="&lt;b&gt;XGBoost&lt;/b&gt;&lt;br&gt;n_estimators=100&lt;br&gt;learning_rate=0.1&lt;br&gt;accuracy=92.8%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="570" y="440" width="160" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="mlp_box" value="&lt;b&gt;MLP Neural Network&lt;/b&gt;&lt;br&gt;hidden=(100,50,25)&lt;br&gt;max_iter=500&lt;br&gt;accuracy=85.9%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="760" y="440" width="160" height="90" as="geometry"/>
        </mxCell>

        <!-- Step 7: Evaluacion -->
        <mxCell id="s7" value="&lt;b&gt;7. Evaluacion&lt;/b&gt;" style="text;html=1;align=center;fontSize=13;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="100" y="590" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="metrics" value="&lt;b&gt;Metricas&lt;/b&gt;&lt;br&gt;- Accuracy&lt;br&gt;- Precision&lt;br&gt;- Recall&lt;br&gt;- F1-Score&lt;br&gt;- Matriz de confusion" style="shape=callout;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;position=0.5;" vertex="1" parent="1">
          <mxGeometry x="60" y="630" width="180" height="140" as="geometry"/>
        </mxCell>
        <mxCell id="confusion" value="&lt;b&gt;Matriz de Confusion&lt;/b&gt;&lt;br&gt;(PNG en resultados/)" style="shape=image;html=1;verticalAlign=top;verticalSpacing=4;aspect=fixed;imageAspectRatio=0;image=\data:image/png;base64,;" vertex="1" parent="1">
          <mxGeometry x="300" y="630" width="120" height="100" as="geometry"/>
        </mxCell>

        <!-- Step 8: Deploy -->
        <mxCell id="s8" value="&lt;b&gt;8. Despliegue&lt;/b&gt;" style="text;html=1;align=center;fontSize=13;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="1080" y="400" width="200" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="deploy" value="&lt;b&gt;Serializacion&lt;/b&gt;&lt;br&gt;model.pkl + scaler.pkl&lt;br&gt;+ label_encoder.pkl&lt;br&gt;&lt;br&gt;&lt;b&gt;Uso en tiempo real:&lt;/b&gt;&lt;br&gt;joblib.load() → predict()" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1060" y="440" width="200" height="120" as="geometry"/>
        </mxCell>

        <!-- Winner badge -->
        <mxCell id="winner" value="&lt;b&gt;★ MEJOR MODELO ★&lt;/b&gt;" style="text;html=1;align=center;fontSize=12;fontColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="585" y="540" width="140" height="20" as="geometry"/>
        </mxCell>

        <!-- ARROWS -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s1" target="s2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s2" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s3" target="s4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;curved=1;" edge="1" source="s4" target="s5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s5" target="rf_box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a5b" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s5" target="xgb_box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a5c" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="s5" target="mlp_box" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a6" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="rf_box" target="metrics" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a7" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="xgb_box" target="deploy" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
